      "parameters": {
        "jsCode": "try {\n  const text = $input.item.json.candidates[0].content.parts[0].text.replace(/```json|```/g, \"\").trim();\n  const event = JSON.parse(text);\n  return {\n    json: {\n      supabase_payload: {\n        company_name: \"NVIDIA\",\n        event_date: event.date,\n        description: event.event\n      }\n    }\n  };\n} catch (e) {\n  return { json: { supabase_payload: { company_name: \"NVIDIA\", event_date: \"1993-04-05\", description: \"NVIDIA specialized in graphics processing.\" } } };\n}"
