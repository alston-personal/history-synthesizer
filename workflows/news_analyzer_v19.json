      "parameters": {
        "jsCode": "return {\n  json: {\n    gemini_payload: {\n      contents: [{\n        parts: [{ text: \"Extract milestone as JSON {\\\"date\\\":\\\"YYYY-MM-DD\\\", \\\"event\\\":\\\"...\\\"} from: \" + $input.item.json.content_text }]\n      }]\n    }\n  }\n};"
