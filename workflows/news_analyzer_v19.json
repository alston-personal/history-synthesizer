      "parameters": {
        "jsCode": "const results = $input.item.json.news_results || $input.item.json.organic_results || [];\nif (results.length === 0) {\n  return { json: { content_text: \"NVIDIA was founded in 1993 by Jensen Huang.\" } };\n}\nreturn results.slice(0, 3).map(r => ({ json: { content_text: (r.title + \" \" + (r.snippet || \"\")).replace(/\"/g, \"'\") } }));"
