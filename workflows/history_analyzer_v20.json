            "parameters": {
                "jsCode": "const results = ($input.item.json.organic_results || []).concat($input.item.json.news_results || []);\nreturn results.slice(0, 5).map(r => ({\n  json: {\n    text: `Title: ${r.title}. Snippet: ${r.snippet || ''}`,\n    link: r.link\n  }\n}));"
