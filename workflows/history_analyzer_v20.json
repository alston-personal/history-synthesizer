            "type": "n8n-nodes-base.basicLlmChain",
            "typeVersion": 1,
            "position": [
                850,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "try {\n  const text = $input.item.json.text.replace(/```json|```/g, \"\").trim();\n  return { json: JSON.parse(text) };\n} catch (e) {\n  return { json: { date: \"Unknown\", event: \"Extraction failed\" } };\n}"
            },
