# History Synthesizer - API Keys Configuration
# Copy this file to .env and fill in your actual keys

# SerpAPI (Google Search)
# Get your key from: https://serpapi.com/manage-api-key
SERPAPI_KEY=your_serpapi_key_here

# OpenAI API
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Supabase
# Get from your Supabase project settings
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Optional: YouTube API (if you want to analyze videos)
YOUTUBE_API_KEY=your_youtube_key_here
